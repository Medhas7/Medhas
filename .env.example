# SARATHI OS environment configuration
#
# If these Supabase variables are ABSENT, SARATHI OS automatically runs in
# local mock mode: an in-memory seeded dataset, no network calls, full UI.
# Add them to switch to a live Supabase Postgres + Auth backend.

# Public (browser-safe) Supabase credentials
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only service role key (NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Model providers — placeholders for v2 agent wiring.
# The /api/agent route runs a deterministic local engine until these are set.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Which provider the agent should prefer when keys exist: openai | anthropic | gemini
SARATHI_MODEL_PROVIDER=anthropic
